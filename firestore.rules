rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.superadmin == true ||
        request.auth.token.role == "admin"
      );
    }

    function isOwner(uid) {
      return isSignedIn() && uid is string && request.auth.uid == uid;
    }

    function isDraftOwner() {
      return isOwner(resource.data.userId);
    }

    function isDraftOwnerOnCreate() {
      return isOwner(request.resource.data.userId);
    }

    function isPublishedTemplateResource() {
      return (!("estado" in resource.data) || resource.data.estado != "archived") &&
        (!("estadoEditorial" in resource.data) || resource.data.estadoEditorial == "publicada");
    }

    function isPublishedTemplateCatalogResource() {
      return resource.data.estado == "active" &&
        resource.data.estadoEditorial == "publicada";
    }

    match /borradores/{draftId} {
      allow create: if isDraftOwnerOnCreate();
      allow read, delete: if isDraftOwner();
      allow update: if isDraftOwner() &&
        request.resource.data.userId == resource.data.userId;
    }

    match /plantillas/{templateId} {
      allow read: if isSignedIn() && isPublishedTemplateResource();
      allow create, update, delete: if false;
    }

    match /plantillas_catalog/{templateId} {
      allow read: if isPublishedTemplateCatalogResource();
      allow create, update, delete: if false;
    }

    match /plantillas_tags/{tagId} {
      allow read, write: if false;
    }

    match /analyticsEvents/{document=**} {
      allow read, write: if false;
    }

    match /analyticsUsers/{document=**} {
      allow read, write: if false;
    }

    match /analyticsInvitations/{document=**} {
      allow read, write: if false;
    }

    match /analyticsDaily/{document=**} {
      allow read, write: if false;
    }

    match /analyticsWeekly/{document=**} {
      allow read, write: if false;
    }

    match /analyticsMonthly/{document=**} {
      allow read, write: if false;
    }

    match /analyticsTemplates/{document=**} {
      allow read, write: if false;
    }

    match /analyticsCohorts/{document=**} {
      allow read, write: if false;
    }

    match /analyticsJobs/{document=**} {
      allow read, write: if false;
    }

    match /analyticsExports/{document=**} {
      allow read, write: if false;
    }

    match /site_settings/{document=**} {
      allow read, write: if false;
    }

    match /app_config/{document=**} {
      allow read, write: if false;
    }

    match /publication_checkout_sessions/{document=**} {
      allow read, write: if false;
    }

    match /public_slug_reservations/{document=**} {
      allow read, write: if false;
    }

    match /publication_discount_codes/{document=**} {
      allow read, write: if false;
    }

    match /publication_discount_code_usage/{document=**} {
      allow read, write: if false;
    }

    match /iconos/{iconId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /iconos_archived/{iconId} {
      allow read, write: if isAdmin();
    }

    match /iconos_usage_snapshots/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /iconos_audit/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /decoraciones/{decorId} {
      allow read, write: if isAdmin();
    }

    match /decoraciones_archived/{decorId} {
      allow read, write: if isAdmin();
    }

    match /decoraciones_audit/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Compatibility fallback for the rest of current app documents.
    match /{collection}/{document=**} {
      allow read, write: if isSignedIn() &&
        collection != "borradores" &&
        collection != "plantillas" &&
        collection != "plantillas_catalog" &&
        collection != "plantillas_tags" &&
        collection != "site_settings" &&
        collection != "app_config" &&
        collection != "publication_checkout_sessions" &&
        collection != "public_slug_reservations" &&
        collection != "publication_discount_codes" &&
        collection != "publication_discount_code_usage";
    }
  }
}
