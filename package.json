{
   "type": "module",
   "name": "reservaeldia",
   "version": "1.0.0",
   "scripts": {
      "dev": "cross-env NEXT_PUBLIC_FIREBASE_MODE=prod next dev",
      "dev:functions": "npm --prefix functions run build && cross-env NEXT_PUBLIC_FIREBASE_MODE=functions-local concurrently -k \"npm --prefix functions run build:watch\" \"firebase emulators:start --only functions\" \"next dev\"",
      "emulators": "npm --prefix functions run build && firebase emulators:start --only auth,firestore,functions",
      "dev:emulators": "npm --prefix functions run build && cross-env NEXT_PUBLIC_FIREBASE_MODE=emulators concurrently -k \"npm --prefix functions run build:watch\" \"firebase emulators:start --only auth,firestore,functions\" \"next dev\"",
      "dev:reset": "node -e \"const fs=require('fs'); ['.next','.next-dev'].forEach((d)=>fs.rmSync(d,{recursive:true,force:true}))\" && next dev",
      "build": "next build",
      "export": "next export",
      "templates:seed:dry": "node scripts/seedTemplateContracts.cjs --dry-run",
      "templates:seed:apply": "node scripts/seedTemplateContracts.cjs --apply",
      "templates:editorial:backfill:dry": "node scripts/backfillTemplateEditorialWorkflow.cjs --dry-run",
      "templates:editorial:backfill:apply": "node scripts/backfillTemplateEditorialWorkflow.cjs --apply",
      "templates:editorial:audit:legacy": "node scripts/auditLegacyTemplateWorkspaceDrafts.cjs",
      "templates:validate:mapping": "node scripts/validateTemplateMapping.cjs",
      "pricing:seed:dry": "node scripts/seedPricingConfig.cjs --dry-run",
      "pricing:seed:apply": "node scripts/seedPricingConfig.cjs --apply",
      "inline:probe": "node scripts/inlineOverlayMatrixProbe.mjs",
      "icons:categories:normalize:dry": "node scripts/normalizeIconCategoriesCase.cjs --dry-run",
      "icons:categories:normalize:apply": "node scripts/normalizeIconCategoriesCase.cjs --apply",
      "deploy:functions:batched": "node scripts/deployFunctionsBatched.cjs",
      "deploy:full": "npm run build && firebase deploy --only hosting && npm run deploy:functions:batched",
      "deploy:hosting": "npm run build && firebase deploy --only hosting"
   },
   "dependencies": {
      "@types/uuid": "^10.0.0",
      "browser-image-compression": "^2.0.2",
      "firebase": "^11.7.3",
      "firebase-admin": "^13.4.0",
      "fs": "^0.0.1-security",
      "html2canvas": "^1.4.1",
      "konva": "^9.3.20",
      "lucide-react": "^0.511.0",
      "mime": "^4.0.7",
      "next": "^15.3.2",
      "path": "^0.12.7",
      "pica": "^9.0.1",
      "puppeteer": "^24.14.0",
      "react": "latest",
      "react-color": "^2.19.3",
      "react-colorful": "^5.6.1",
      "react-dom": "latest",
      "react-icons": "^5.5.0",
      "react-konva": "^19.0.3",
      "tailwind-scrollbar-hide": "^4.0.0",
      "use-image": "^1.1.4",
      "uuid": "^11.1.0",
      "webfontloader": "^1.6.28"
   },
   "devDependencies": {
      "autoprefixer": "^10.4.14",
      "concurrently": "^9.2.1",
      "cross-env": "^7.0.3",
      "postcss": "^8.4.21",
      "tailwindcss": "^3.4.1"
   },
   "engines": {
      "node": "20"
   }
}
